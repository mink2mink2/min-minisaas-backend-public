# Environment
# development: HTTP OK, 모든 CORS 허용
# production: HTTPS 필수, COOKIE_SECURE=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/minisaas_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-in-production
API_SECRET_KEY=your-api-secret-key-change-in-production
BCRYPT_ROUNDS=12

# Token TTL (Legacy - email+password)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Session (Web Platform)
# COOKIE_SECURE를 명시하지 않으면 ENVIRONMENT에 따라 자동 설정
# - development: false (HTTP 허용)
# - production: true (HTTPS 필수)
SESSION_TTL_MIN=30
# COOKIE_SECURE=false  # 개발 환경에서는 생략하거나 false
COOKIE_SAMESITE=lax

# Desktop Auth (OAuth2 PKCE)
DESKTOP_ACCESS_EXPIRE_MINUTES=60
DESKTOP_REFRESH_EXPIRE_DAYS=30

# IoT Device Auth
DEVICE_ACCESS_EXPIRE_HOURS=24
DEVICE_REFRESH_EXPIRE_DAYS=90

# Firebase (Web & Mobile Platforms)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_JWKS_URI=https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com
FCM_CREDENTIALS_PATH=config/firebase-adminsdk.json

# Google OAuth (Desktop Platform)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Kakao OAuth
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Naver OAuth
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# MinIO (파일 저장소)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
